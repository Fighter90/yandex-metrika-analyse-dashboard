# dependencies
node_modules/

# build output
dist/
coverage/

# playwright
test-results/
playwright-report/
.playwright/

# env / secrets
.env
.env.local

# data (gitignored per spec — keep only .gitkeep markers)
/data/*
!/data/reports/
/data/reports/*
!/data/reports/.gitkeep
!/data/decisions/
/data/decisions/*
!/data/decisions/.gitkeep

# Local SQLite + raw API error dumps must NEVER be committed (real Metrika data), from any path —
# the CLIs write these relative to their cwd (e.g. code/backend/data/ when run there).
**/data/errors/
**/*.sqlite
**/*.sqlite-shm
**/*.sqlite-wal
code/backend/data/

# logs / os
*.log
.DS_Store

# Claude Code session lock (never commit)
.claude/scheduled_tasks.lock

*.docx

# qwen worktrees / local agent settings
.qwen/
