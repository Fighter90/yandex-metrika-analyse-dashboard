# ── Yandex Metrika OAuth ────────────────────────────────────────────────
# 1. Register an app at https://oauth.yandex.ru with scope: metrika:read
# 2. Get an OAuth token (implicit flow):
#    https://oauth.yandex.ru/authorize?response_type=token&client_id=<YANDEX_CLIENT_ID>
#    The token comes back in the URL fragment (#access_token=...).
# NEVER commit a real token or client secret. This file holds placeholders only.
YANDEX_OAUTH_TOKEN=YOUR_OAUTH_TOKEN_HERE
YANDEX_CLIENT_ID=YOUR_CLIENT_ID_HERE
YANDEX_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
OAUTH_REDIRECT_URI=https://oauth.yandex.ru/verification_code

# ── Metrika counter / runtime ───────────────────────────────────────────
COUNTER_ID=54280963
TIMEZONE=Europe/Moscow
PORT=5173
API_PORT=4000
ARCHIVED_GOAL_ID_THRESHOLD=77
LOW_UTM_COVERAGE_RATIO=0.7

# ── Report rendering (PDF) ──────────────────────────────────────────────
# PDF export uses puppeteer-core, which does NOT bundle Chromium (keeps installs fast).
# Point this at a local Chrome/Chromium binary, e.g.:
#   macOS:  /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#   Linux:  /usr/bin/chromium-browser  (or `which google-chrome`)
# DOCX export needs nothing extra. Leave empty if you only export DOCX.
PUPPETEER_EXECUTABLE_PATH=
